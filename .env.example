# =============================================
# SOCIAL MEDIA MANAGER — API Credentials
# =============================================
# IT: Copia questo file in .env e compila i valori.
#     Guida completa: .claude/setup/api-credentials.md
#     NON committare mai il file .env su git.
#
# EN: Copy this file to .env and fill in your values.
#     Full guide: .claude/setup/api-credentials.md
#     NEVER commit the .env file to git.
# =============================================

# --- LinkedIn ---
# IT: Ottieni queste credenziali da https://developer.linkedin.com/
# EN: Get these credentials from https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_ID=your_linkedin_person_id

# --- X (Twitter) ---
# IT: Ottieni queste credenziali da https://developer.x.com/
# EN: Get these credentials from https://developer.x.com/
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_API_KEY=your_x_api_key
X_API_KEY_SECRET=your_x_api_key_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# --- Threads ---
# IT: Ottieni queste credenziali da https://developers.facebook.com/docs/threads
# EN: Get these credentials from https://developers.facebook.com/docs/threads
THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id
